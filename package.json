{
  "name": "@potato4d/translate-cli",
  "version": "0.1.0",
  "description": "Translate text through local Agent CLIs",
  "type": "module",
  "bin": {
    "t": "dist/t.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:binary": "bun build src/t.ts --compile --outfile dist/t",
    "build:release": "node scripts/build-release.mjs",
    "prepack": "npm run build",
    "test": "npm run build && node --test dist/t.test.js",
    "test:binary": "npm run build:binary && ./dist/t --version"
  },
  "files": [
    "dist/t.js"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/potato4d/translate-cli.git"
  },
  "devDependencies": {
    "@types/node": "^24.10.1",
    "bun": "^1.3.13",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20"
  }
}
