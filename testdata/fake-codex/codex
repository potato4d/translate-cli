#!/bin/sh
set -eu

output=""
has_sandbox=0
has_approval=0
has_color=0
has_repo=0
has_exec=0
has_low_reasoning=0
has_fast_model=0
has_ignore_user_config=0
has_ignore_rules=0
has_ephemeral=0
has_json=0
has_no_permissions=0
has_no_apps=0
has_no_environment=0
has_no_apply_patch=0
prompt_arg=""

while [ "$#" -gt 0 ]; do
  case "$1" in
    login)
      if [ "${2:-}" = "status" ]; then
        exit 0
      fi
      echo "fake-codex: expected login status" >&2
      exit 64
      ;;
    exec)
      has_exec=1
      shift
      ;;
    -c|--config)
      case "$2" in
        'model_reasoning_effort="low"')
          has_low_reasoning=1
          ;;
        include_permissions_instructions=false)
          has_no_permissions=1
          ;;
        include_apps_instructions=false)
          has_no_apps=1
          ;;
        include_environment_context=false)
          has_no_environment=1
          ;;
        include_apply_patch_tool=false)
          has_no_apply_patch=1
          ;;
        *)
          exit 65
          ;;
      esac
      shift 2
      ;;
    -m|--model)
      [ "$2" = "gpt-5.3-codex-spark" ] || exit 65
      has_fast_model=1
      shift 2
      ;;
    --output-last-message)
      output="$2"
      shift 2
      ;;
    --json)
      has_json=1
      shift
      ;;
    --sandbox)
      [ "$2" = "read-only" ] || exit 65
      has_sandbox=1
      shift 2
      ;;
    --ask-for-approval)
      [ "$2" = "never" ] || exit 65
      has_approval=1
      shift 2
      ;;
    --color)
      [ "$2" = "never" ] || exit 65
      has_color=1
      shift 2
      ;;
    --skip-git-repo-check)
      has_repo=1
      shift
      ;;
    --ignore-user-config)
      has_ignore_user_config=1
      shift
      ;;
    --ignore-rules)
      has_ignore_rules=1
      shift
      ;;
    --ephemeral)
      has_ephemeral=1
      shift
      ;;
    *)
      if [ "${1#-}" = "$1" ]; then
        prompt_arg="$1"
      fi
      shift
      ;;
  esac
done

[ "$has_exec" -eq 1 ] || exit 64
[ "$has_json" -eq 1 ] || exit 66
[ "$has_sandbox" -eq 1 ] || exit 67
[ "$has_approval" -eq 1 ] || exit 67
[ "$has_color" -eq 1 ] || exit 67
[ "$has_repo" -eq 1 ] || exit 67
[ "$has_low_reasoning" -eq 1 ] || exit 67
[ "$has_fast_model" -eq 1 ] || exit 67
[ "$has_ignore_user_config" -eq 1 ] || exit 67
[ "$has_ignore_rules" -eq 1 ] || exit 67
[ "$has_ephemeral" -eq 1 ] || exit 67
[ "$has_no_permissions" -eq 1 ] || exit 67
[ "$has_no_apps" -eq 1 ] || exit 67
[ "$has_no_environment" -eq 1 ] || exit 67
[ "$has_no_apply_patch" -eq 1 ] || exit 67

if [ -n "$prompt_arg" ]; then
  prompt="$prompt_arg"
else
  prompt="$(cat)"
fi
case "$prompt" in
  *"Return only the translated text."*) ;;
  *) echo "fake-codex: prompt missing raw text instruction" >&2; exit 68 ;;
esac

printf '{"type":"thread.started","thread_id":"fake"}\n'
printf '{"type":"turn.started"}\n'
printf '{"type":"item.completed","item":{"type":"agent_message","text":"こんにちは"}}\n'
if [ -n "$output" ]; then
  printf 'こんにちは' > "$output"
fi
