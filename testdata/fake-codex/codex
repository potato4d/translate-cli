#!/bin/sh
set -eu

output=""
schema=""
has_sandbox=0
has_approval=0
has_color=0
has_repo=0
has_exec=0

while [ "$#" -gt 0 ]; do
  case "$1" in
    login)
      if [ "${2:-}" = "status" ]; then
        exit 0
      fi
      echo "fake-codex: expected login status" >&2
      exit 64
      ;;
    exec)
      has_exec=1
      shift
      ;;
    --output-last-message)
      output="$2"
      shift 2
      ;;
    --output-schema)
      schema="$2"
      shift 2
      ;;
    --sandbox)
      [ "$2" = "read-only" ] || exit 65
      has_sandbox=1
      shift 2
      ;;
    --ask-for-approval)
      [ "$2" = "never" ] || exit 65
      has_approval=1
      shift 2
      ;;
    --color)
      [ "$2" = "never" ] || exit 65
      has_color=1
      shift 2
      ;;
    --skip-git-repo-check)
      has_repo=1
      shift
      ;;
    *)
      shift
      ;;
  esac
done

[ "$has_exec" -eq 1 ] || exit 64
[ -n "$output" ] || exit 66
[ -n "$schema" ] || exit 66
[ "$has_sandbox" -eq 1 ] || exit 67
[ "$has_approval" -eq 1 ] || exit 67
[ "$has_color" -eq 1 ] || exit 67
[ "$has_repo" -eq 1 ] || exit 67

prompt="$(cat)"
case "$prompt" in
  *"You are a translation engine."*) ;;
  *) echo "fake-codex: prompt missing role" >&2; exit 68 ;;
esac

printf '{"translated_text":"こんにちは"}' > "$output"
printf 'ignored progress\n'
